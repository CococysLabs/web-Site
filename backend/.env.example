# ===================================
# EJEMPLO DE VARIABLES DE ENTORNO
# ===================================
# Copiar este archivo como .env y completar con valores reales
# NO SUBIR EL ARCHIVO .env AL REPOSITORIO

# Base de datos (Neon PostgreSQL)
DATABASE_URL=postgresql://usuario:password@host.neon.tech/database?sslmode=require

# JWT Secret (generar con: openssl rand -hex 32)
SECRET_KEY=tu_secret_key_aqui_muy_largo_y_aleatorio

# Algoritmo JWT
ALGORITHM=HS256

# Tiempo de expiración del token (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Google Drive
GOOGLE_CREDENTIALS_FILE=cococys-driv-105652f59c31.json
GOOGLE_DRIVE_FOLDER_ID=tu_folder_id_de_google_drive

# Google Gemini API
GEMINI_API_KEY=tu_api_key_de_gemini

# CORS Origins (separados por comas)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:80

# Entorno
ENVIRONMENT=development
